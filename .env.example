# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# This file lists the environment variables the app expects — names only, no secrets.

# ── Database (Supabase Postgres via Prisma) ──────────────────────────────
# Pooled connection (Supavisor transaction pooler, port 6543) — used by Prisma Client at runtime.
# Must include ?pgbouncer=true&connection_limit=1
DATABASE_URL=
# Direct/session connection (port 5432) — used by the Prisma CLI for migrate/introspect.
DIRECT_URL=

# ── Auth (NextAuth v4) ───────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=            # e.g. http://localhost:3000 in dev

# ── OAuth providers ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── SMTP / transactional email ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=              # e.g. "pseudoEngineer <contact@example.com>"

# ── Misc ─────────────────────────────────────────────────────────────────
MY_IP=                   # your IP, excluded from page-view counts
